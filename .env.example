# TMDB API key (v3 auth) — used at build time by scripts/fetch-posters.ts
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Spotify — powers the live /music page (top tracks & artists).
# Create an app at https://developer.spotify.com/dashboard, then run
# `bun run scripts/spotify-auth.ts` to obtain the refresh token.
# In production these must be set as Cloudflare Pages environment variables.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
